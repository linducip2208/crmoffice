APP_NAME=crmoffice
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crmoffice_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Redis (Production)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail (Production — use SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Storage (Production — S3 compatible)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Search (database for dev, meilisearch for prod)
SCOUT_DRIVER=database
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Spatie Media Library
MEDIA_DISK=public

# Sanctum
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SESSION_DOMAIN=.yourdomain.com

# Numbering prefixes
CRMOFFICE_DEFAULT_CURRENCY=IDR
CRMOFFICE_INVOICE_PREFIX=INV
CRMOFFICE_ESTIMATE_PREFIX=EST
CRMOFFICE_PROPOSAL_PREFIX=PROP
CRMOFFICE_CONTRACT_PREFIX=CON
CRMOFFICE_CREDIT_NOTE_PREFIX=CN
CRMOFFICE_TICKET_PREFIX=T

# Optional Sentry
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Demo data seeding (set true to seed demo records on migrate --seed)
APP_DEMO_SEED=false

# Horizon (Redis-backed queue dashboard at /horizon — auth-protected)
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# Inertia / Vite
VITE_APP_NAME="${APP_NAME}"

# License v3 (whitelabel.co.id pairing kit)
LICENSE_SERVER_URL=https://whitelabel.co.id
LICENSE_DEV_BYPASS=true            # true di local, false di production
LICENSE_HEARTBEAT_INTERVAL=86400   # 24 jam
LICENSE_HEARTBEAT_GRACE=604800     # 7 hari grace kalau marketplace down
